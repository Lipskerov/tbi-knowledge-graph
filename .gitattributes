# Keep LF on source, config and container files (Docker build needs LF).
*.py        text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.json      text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# Binary assets — never normalize
*.db        binary
*.pdf       binary
*.png       binary
